# OAuth2 Proxy Configuration for {{ oauth2_proxy_name }}
# Generated by Ansible

# HTTP/HTTPS address
http_address="{{ oauth2_proxy_http_address | default('127.0.0.1:' + (oauth2_proxy_port | string)) }}"

# Authentication
authenticated_emails_file = "{{ oauth2_proxy_install_dir | default('/opt/oauth2_proxy_' + oauth2_proxy_name) }}/authenticated_emails.txt"

# OAuth2 Configuration
provider = "{{ oauth2_proxy_provider | default('google') }}"
client_id = "{{ oauth2_proxy_client_id }}"
client_secret = "{{ oauth2_proxy_client_secret }}"

# Cookie Configuration
cookie_domains = {{ oauth2_proxy_cookie_domains | default(['.' + oauth2_proxy_domains[0].split('.')[1:] | join('.')]) | to_nice_json }}
cookie_secure = {{ oauth2_proxy_cookie_secure | default(true) | lower }}
cookie_samesite = "{{ oauth2_proxy_cookie_samesite | default('lax') }}"

# URL Configuration
redirect_url = "{{ oauth2_proxy_redirect_url }}"
set_xauthrequest = {{ oauth2_proxy_set_xauthrequest | default(true) | lower }}
upstreams = {{ oauth2_proxy_upstreams | to_nice_json }}

# Cookie Secret
cookie_secret = "{{ oauth2_proxy_cookie_secret }}"

# Additional configuration
{% if oauth2_proxy_scope is defined %}
scope = "{{ oauth2_proxy_scope }}"
{% endif %}

{% if oauth2_proxy_custom_config is defined %}
# Custom configuration
{{ oauth2_proxy_custom_config }}
{% endif %}